{
  "name": "preventivi-pwa",
  "version": "1.1.0",
  "private": true,
  "description": "PWA locale per creare preventivi con dashboard, template, stampa e PDF on demand.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:publish": "vite build && electron-builder --win --publish always",
    "icons": "node scripts/build-icons.mjs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^7.1.7",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.preventivi.app",
    "productName": "Preventivi",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "C:\\PrevBuild\\v${version}",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Preventivi-Setup.exe",
      "icon": "C:\\PrevBuild\\icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Preventivi",
      "installerIcon": "C:\\PrevBuild\\icon.ico",
      "uninstallerIcon": "C:\\PrevBuild\\icon.ico",
      "deleteAppDataOnUninstall": false,
      "script": "build/installer.nsi"
    },
    "publish": {
      "provider": "github",
      "owner": "SuiramSpark",
      "repo": "Preventivi"
    }
  }
}
